---
import type { Favorite } from "../data/schema";
import FavoriteCard from "./FavoriteCard.astro";

interface Props {
  favorites: Favorite[];
}

const { favorites } = Astro.props;
---

<section>
  <div class="results-head">
    <p><span id="results-count">{favorites.length}</span> favorites</p>
    <div class="view-toggle" role="group" aria-label="View mode">
      <button type="button" class="view-toggle-btn active" data-view="grid" aria-pressed="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="1em"
          height="1em"
          viewBox="0 0 24 24">
            <title></title>
            <path
              fill="currentColor"
              d="M5 11q-.825 0-1.412-.587T3 9V5q0-.825.588-1.412T5 3h4q.825 0 1.413.588T11 5v4q0 .825-.587 1.413T9 11zm0 10q-.825 0-1.412-.587T3 19v-4q0-.825.588-1.412T5 13h4q.825 0 1.413.588T11 15v4q0 .825-.587 1.413T9 21zm10-10q-.825 0-1.412-.587T13 9V5q0-.825.588-1.412T15 3h4q.825 0 1.413.588T21 5v4q0 .825-.587 1.413T19 11zm0 10q-.825 0-1.412-.587T13 19v-4q0-.825.588-1.412T15 13h4q.825 0 1.413.588T21 15v4q0 .825-.587 1.413T19 21zM5 9h4V5H5zm10 0h4V5h-4zm0 10h4v-4h-4zM5 19h4v-4H5zM9 9"/>
        </svg>
      </button>
      <button type="button" class="view-toggle-btn" data-view="list" aria-pressed="false">
        <svg 
          xmlns="http://www.w3.org/2000/svg"
          width="1em"
          height="1em"
          viewBox="0 0 24 24">
            <title></title>
            <path 
              fill="currentColor" 
              d="M10 20q-.825 0-1.412-.587T8 18t.588-1.412T10 16h10q.825 0 1.413.588T22 18t-.587 1.413T20 20zm0-6q-.825 0-1.412-.587T8 12t.588-1.412T10 10h10q.825 0 1.413.588T22 12t-.587 1.413T20 14zm0-6q-.825 0-1.412-.587T8 6t.588-1.412T10 4h10q.825 0 1.413.588T22 6t-.587 1.413T20 8zm-7.413-.587Q2 6.825 2 6t.588-1.412T4 4t1.413.588T6 6t-.587 1.413T4 8t-1.412-.587M4 14q-.825 0-1.412-.587T2 12t.588-1.412T4 10t1.413.588T6 12t-.587 1.413T4 14m0 6q-.825 0-1.412-.587T2 18t.588-1.412T4 16t1.413.588T6 18t-.587 1.413T4 20"/>
        </svg>
      </button>
    </div>
  </div>

  <div class="favorites-grid" id="favorites-grid" data-view="grid">
    {favorites.map((favorite) => <FavoriteCard favorite={favorite} />)}
  </div>

  <p id="empty-state" class="empty-state" hidden>No favorites match the current search/filter.</p>
</section>
