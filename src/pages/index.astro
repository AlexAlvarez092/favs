---
import BaseLayout from "../layouts/BaseLayout.astro";
import FavoritesList from "../components/FavoritesList.astro";
import SearchBox from "../components/SearchBox.astro";
import TagFilter from "../components/TagFilter.astro";
import favoritesData from "../data/favorites.json";
import "../styles/components.css";

const favorites = favoritesData.favorites;
const tags = [...new Set(favorites.flatMap((favorite) => favorite.tags))].sort();
---

<BaseLayout title="favs | Favorite Links">
  <section class="controls-shell">
    <SearchBox />
  </section>

  <section class="content-layout">
    <aside class="tags-panel">
      <TagFilter tags={tags} />
    </aside>
    <div class="favorites-panel">
      <FavoritesList favorites={favorites} />
    </div>
  </section>

  <script>
    const searchInput = document.querySelector("#search-input");
    const tagButtons = Array.from(document.querySelectorAll(".tag-toggle"));
    const cards = Array.from(document.querySelectorAll("[data-favorite]"));
    const resultsCount = document.querySelector("#results-count");
    const emptyState = document.querySelector("#empty-state");
    const favoritesGrid = document.querySelector("#favorites-grid");
    const viewButtons = Array.from(document.querySelectorAll(".view-toggle-btn"));
    const desktopViewMedia = window.matchMedia("(min-width: 768px)");
    let desktopView = "grid";

    const activeTags = new Set();

    const updateFilters = () => {
      const query = (searchInput?.value || "").trim().toLowerCase();
      let visible = 0;

      cards.forEach((card) => {
        const searchSource = card.getAttribute("data-search") || "";
        const tagsAttr = card.getAttribute("data-tags") || "";
        const cardTags = tagsAttr ? tagsAttr.split("|") : [];

        const matchesQuery = !query || searchSource.includes(query);
        const matchesTags =
          activeTags.size === 0 || [...activeTags].every((tag) => cardTags.includes(tag));

        const shouldShow = matchesQuery && matchesTags;
        card.toggleAttribute("hidden", !shouldShow);

        if (shouldShow) {
          visible += 1;
        }
      });

      if (resultsCount) {
        resultsCount.textContent = String(visible);
      }

      if (emptyState) {
        emptyState.toggleAttribute("hidden", visible !== 0);
      }
    };

    searchInput?.addEventListener("input", updateFilters);

    tagButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const tag = button.getAttribute("data-tag");
        if (!tag) return;

        if (activeTags.has(tag)) {
          activeTags.delete(tag);
          button.setAttribute("aria-pressed", "false");
          button.classList.remove("active");
        } else {
          activeTags.add(tag);
          button.setAttribute("aria-pressed", "true");
          button.classList.add("active");
        }

        updateFilters();
      });
    });

    const setView = (view, persistDesktop = true) => {
      if (!favoritesGrid) return;

      favoritesGrid.setAttribute("data-view", view);

      if (persistDesktop && desktopViewMedia.matches) {
        desktopView = view;
      }

      viewButtons.forEach((button) => {
        const isActive = button.getAttribute("data-view") === view;
        button.classList.toggle("active", isActive);
        button.setAttribute("aria-pressed", isActive ? "true" : "false");
      });
    };

    const applyResponsiveView = () => {
      if (desktopViewMedia.matches) {
        setView(desktopView, false);
      } else {
        setView("list", false);
      }
    };

    viewButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const view = button.getAttribute("data-view");
        if (!view) return;
        setView(view);
      });
    });

    applyResponsiveView();
    desktopViewMedia.addEventListener("change", applyResponsiveView);
  </script>
</BaseLayout>
